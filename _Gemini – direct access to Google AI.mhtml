    <meta name=3D"viewport" content=3D"width=3Ddevice-width, initial-scale=
=3D1.0">
    <title>Airport Road Quetta - LOS Calculator</title>
    <!-- Tailwind CSS for styling -->
   =20
    <!-- SheetJS for Excel processing -->
   =20
    <!-- FontAwesome for Icons -->
    <link rel=3D"stylesheet" href=3D"https://cdnjs.cloudflare.com/ajax/libs=
/font-awesome/6.0.0/css/all.min.css">
    <!-- Markdown Parser for AI Response -->
   =20
   =20
   =20
</head>
<body class=3D"bg-slate-100 text-slate-800">

    <!-- Header -->
    <header class=3D"bg-blue-900 text-white p-6 shadow-lg relative">
        <div class=3D"container mx-auto flex justify-between items-center">
            <div>
                <h1 class=3D"text-3xl font-bold"><i class=3D"fas fa-road mr=
-2"></i>Airport Road Quetta - LOS Calculator</h1>
                <p class=3D"opacity-80 mt-2">Operational Analysis based on =
HCM Formulas &amp; FYDP Methodology</p>
            </div>
           =20
            <!-- API Key Settings -->
            <div class=3D"relative group">
                <button class=3D"text-white hover:text-blue-200 transition"=
>
                    <i class=3D"fas fa-cog fa-lg"></i>
                </button>
                <div id=3D"settingsPanel" class=3D"absolute right-0 top-10 =
bg-white text-gray-800 p-4 rounded shadow-xl w-72 z-50 border border-gray-2=
00 hidden">
                    <label class=3D"block text-sm font-bold mb-2">Gemini AP=
I Key</label>
                    <input type=3D"password" id=3D"apiKeyInput" class=3D"w-=
full border rounded p-2 text-sm mb-2" placeholder=3D"Paste API Key here..."=
>
                    <button class=3D"bg-blue-600 text-white text-xs px-3 py=
-1 rounded hover:bg-blue-700 w-full">Save Key</button>
                    <p class=3D"text-xs text-gray-400 mt-2">Key is stored l=
ocally in browser.</p>
                </div>
            </div>
        </div>
    </header>

    <div class=3D"container mx-auto p-6 grid grid-cols-1 lg:grid-cols-3 gap=
-8">
       =20
        <!-- Left Column: Inputs -->
        <div class=3D"lg:col-span-2 space-y-6">
           =20
            <!-- Section 1: Traffic Volume Source -->
            <div class=3D"bg-white p-6 rounded-lg shadow-md border-l-4 bord=
er-blue-500">
                <h2 class=3D"text-xl font-bold mb-4 border-b pb-2">1. Traff=
ic Volume Data</h2>
               =20
                <div class=3D"mb-4">
                    <label class=3D"block font-semibold mb-2">Data Source:<=
/label>
                    <div class=3D"flex space-x-4 mb-3">
                        <label class=3D"inline-flex items-center">
                            <input type=3D"radio" name=3D"sourceType" value=
=3D"manual" checked=3D"" class=3D"form-radio text-blue-600">
                            <span class=3D"ml-2">Manual Input</span>
                        </label>
                        <label class=3D"inline-flex items-center">
                            <input type=3D"radio" name=3D"sourceType" value=
=3D"file" class=3D"form-radio text-blue-600">
                            <span class=3D"ml-2">Upload Excel/CSV</span>
                        </label>
                    </div>
                </div>

                <!-- Manual Input -->
                <div id=3D"manualInputBlock">
                    <label class=3D"block text-sm font-medium text-gray-700=
">Hourly Volume (V) (vehicles/hour)</label>
                    <input type=3D"number" id=3D"manualVolume" class=3D"mt-=
1 block w-full rounded-md border-gray-300 shadow-sm bg-gray-50 border p-2 f=
ocus:ring-blue-500 focus:border-blue-500" placeholder=3D"e.g. 1800">
                </div>

                <!-- File Input -->
                <div id=3D"fileInputBlock" class=3D"hidden">
                    <label class=3D"block text-sm font-medium text-gray-700=
 mb-2">Upload File (Contains Volume Column)</label>
                    <input type=3D"file" id=3D"fileUpload" class=3D"block w=
-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full=
 file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-bl=
ue-700 hover:file:bg-blue-100">
                    <p id=3D"fileStatus" class=3D"text-sm text-green-600 mt=
-2 hidden"><i class=3D"fas fa-check"></i> File loaded. Found max volume: <s=
pan id=3D"fileMaxVol" class=3D"font-bold"></span></p>
                    <p class=3D"text-xs text-gray-500 mt-1">Note: Tool look=
s for the highest value in the first numeric column of the file.</p>
                </div>
            </div>

            <!-- Section 2: Road & Traffic Parameters -->
            <div class=3D"bg-white p-6 rounded-lg shadow-md border-l-4 bord=
er-indigo-500">
                <h2 class=3D"text-xl font-bold mb-4 border-b pb-2">2. Roadw=
ay Parameters</h2>
               =20
                <div class=3D"grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- PHF -->
                    <div>
                        <label class=3D"block text-sm font-medium text-gray=
-700">Peak Hour Factor (PHF)</label>
                        <input type=3D"number" id=3D"phf" step=3D"0.01" val=
ue=3D"0.92" class=3D"mt-1 block w-full border border-gray-300 rounded-md p-=
2" placeholder=3D"0.80 - 1.00">
                        <p class=3D"text-xs text-gray-400">Default 0.92 if =
unknown</p>
                    </div>
                   =20
                    <!-- Number of Lanes -->
